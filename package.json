{
  "name": "opengrove",
  "version": "0.1.0",
  "type": "module",
  "description": "Local-first workspace where people and agents talk, remember, and collaborate.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Olorinm/opengrove#readme",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/Olorinm/opengrove.git"
  },
  "bugs": {
    "url": "https://github.com/Olorinm/opengrove/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "opengrove": "dist/cli.js"
  },
  "files": [
    "assets",
    "dist",
    "extension",
    "scripts/provider-http-capture-addon.py",
    "scripts/provider-http-capture.mjs",
    "src/skills/bundled",
    "web-dist",
    "LICENSE",
    "PROJECT_OVERVIEW.md",
    "PROJECT_OVERVIEW.zh-CN.md",
    "README.md",
    "README.zh-CN.md"
  ],
  "scripts": {
    "build": "npm run build:server && npm run build:web",
    "build:server": "npm run clean:server && tsc",
    "build:web": "node scripts/build-web.mjs",
    "clean:server": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "typecheck": "npm run typecheck:server && npm run typecheck:web",
    "typecheck:server": "tsc --noEmit",
    "typecheck:web": "tsc -p web/tsconfig.json --noEmit",
    "check": "npm run check:secrets && npm run typecheck",
    "check:secrets": "node scripts/check-secrets.mjs",
    "smoke": "npm run build:server && node dist/examples/smoke.js",
    "eval": "npm run build:server && node dist/evals/run-evals.js",
    "test:rooms": "npm run build:server && node dist/tests/rooms-store-harness.js",
    "test:harness": "npm run build:server && node dist/tests/skill-harness.js && node dist/tests/kernel-knowledge-harness.js && node dist/tests/native-skill-publisher-harness.js && node dist/tests/claude-code-runtime-harness.js && node dist/tests/claude-agent-sdk-runtime-harness.js && node dist/tests/hermes-runtime-harness.js && node dist/tests/kernel-extension-harness.js && node dist/tests/acp-cli-runtime-harness.js && node dist/tests/openclaw-gateway-runtime-harness.js && node dist/tests/openai-http-runtime-harness.js && node dist/tests/bridge-kernel-selection-harness.js && node dist/tests/server-profile-harness.js && node dist/tests/invite-landing-harness.js",
    "bridge": "npm run build && node dist/server/local-bridge.js",
    "capture:provider": "node scripts/provider-http-capture.mjs",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.133",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@lezer/highlight": "^1.2.3",
    "@lobehub/icons": "^5.8.0",
    "@mariozechner/pi-agent-core": "^0.66.1",
    "@mariozechner/pi-ai": "^0.66.1",
    "@tanstack/react-query": "^5.99.2",
    "@vitejs/plugin-react": "^6.0.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "codemirror": "^6.0.2",
    "lucide-react": "^1.8.0",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "undici": "^7.24.7",
    "zod": "^4.4.3",
    "zustand": "^5.0.12"
  },
  "overrides": {
    "@anthropic-ai/sdk": "^0.95.1",
    "fast-uri": "^3.1.2"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.0",
    "typescript": "^5.7.3",
    "vite": "^8.0.10"
  }
}
